{
  "name": "multi-agent-roundtable",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "assets": "node scripts/generate-assets.mjs",
    "api": "tsx server/index.ts",
    "dev": "vite",
    "dev:all": "concurrently -k -n API,WEB -c cyan,magenta \"npm run api\" \"npm run dev -- --host 127.0.0.1\"",
    "build": "npm run assets && tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "jsdom": "^28.1.0",
    "pngjs": "^7.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
